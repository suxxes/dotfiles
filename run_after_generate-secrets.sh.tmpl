#!/bin/bash
# chezmoi:template:left-delimiter="# {{" right-delimiter="}}"
# Generates ~/.config/secrets/env.fish, AWS config, and SSH key from 1Password.
# Hash: # {{ include "dot_config/fish/conf.d/50-secrets.fish.tmpl" | sha256sum }}

set -e

# {{ if eq .osType "darwin" }}
IS_DARWIN=1
PROFILE_TYPE="# {{ .profile }}"
# {{ else }}
IS_DARWIN=0
PROFILE_TYPE_FILE="/.profile"
if [ -f "$PROFILE_TYPE_FILE" ]; then
    PROFILE_TYPE=$(cat "$PROFILE_TYPE_FILE" | tr -d '[:space:]')
else
    PROFILE_TYPE="default"
fi
# {{ end }}

HOSTNAME=$(hostname)

if [ "$PROFILE_TYPE" = "work" ]; then
    VAULTS=("Secrets" "Secrets: Work")
elif [ "$PROFILE_TYPE" = "personal" ]; then
    VAULTS=("Secrets" "Secrets: Personal")
else
    VAULTS=("Secrets")
fi

if ! command -v op &> /dev/null; then
    echo "ERROR: 1Password CLI not installed" >&2
    exit 0
fi

# Load service account token (Linux) if not already set
if [ "$IS_DARWIN" != "1" ] && [ -z "$OP_SERVICE_ACCOUNT_TOKEN" ] && [ -f "$HOME/.config/op/service-account-token" ]; then
    export OP_SERVICE_ACCOUNT_TOKEN=$(cat "$HOME/.config/op/service-account-token" | tr -d '[:space:]')
fi

if ! op account list &> /dev/null; then
    echo "ERROR: Not authenticated to 1Password" >&2
    exit 0
fi

# {{ if eq .osType "darwin" }}
# macOS app integration: with multiple 1Password accounts, op can't resolve a
# bare --vault query. Default OP_ACCOUNT to the account holding the primary vault.
if [ -z "$OP_ACCOUNT" ] && [ "$(op account list --format=json 2>/dev/null | jq 'length' 2>/dev/null || echo 0)" -gt 1 ]; then
    for ACCT in $(op account list --format=json 2>/dev/null | jq -r '.[].url'); do
        if op vault get "${VAULTS[0]}" --account "$ACCT" &> /dev/null; then
            export OP_ACCOUNT="$ACCT"
            break
        fi
    done
fi
# {{ end }}

# Get all items from configured vaults
ITEMS="[]"
for VAULT in "${VAULTS[@]}"; do
    VAULT_ITEMS=$(op item list --vault "$VAULT" --format json 2>/dev/null || echo "[]")
    ITEMS=$(echo "$ITEMS" "$VAULT_ITEMS" | jq -s 'add | unique_by(.id)')
done

if [ "$ITEMS" = "[]" ]; then
    echo "WARNING: No items found in configured vaults" >&2
    exit 0
fi

SECRETS_DIR="$HOME/.config/secrets"
SECRETS_FILE="$SECRETS_DIR/env.fish"

mkdir -p "$SECRETS_DIR"

echo "# Auto-generated by chezmoi - do not edit" > "$SECRETS_FILE"
echo "# Generated: $(date -Iseconds)" >> "$SECRETS_FILE"
echo "# Hostname: $HOSTNAME" >> "$SECRETS_FILE"
echo "# Profile: $PROFILE_TYPE" >> "$SECRETS_FILE"
echo "# Vaults: ${VAULTS[*]}" >> "$SECRETS_FILE"
echo "" >> "$SECRETS_FILE"

echo "$ITEMS" | jq -r '.[] | "\(.title)|\(.vault.id)"' | while IFS='|' read -r TITLE VAULT_ID; do
    if [[ "$TITLE" == "Service Account Token" ]] || [[ "$TITLE" == "LXC SSH Key" ]] || [[ "$TITLE" == "AWS SSO:"* ]] || [[ "$TITLE" == "AWS Key:"* ]]; then
        continue
    fi

    if [[ "$TITLE" == LXC:* ]]; then
        ITEM_HOST=$(echo "$TITLE" | sed 's/^LXC: *//')
        if [[ "$ITEM_HOST" != "$HOSTNAME" ]]; then
            continue
        fi
        echo "# From: $TITLE (container-specific)" >> "$SECRETS_FILE"
    else
        echo "# From: $TITLE" >> "$SECRETS_FILE"
    fi

    FIELDS=$(op item get "$TITLE" --vault "$VAULT_ID" --format json 2>/dev/null | \
        jq -r '.fields[]? | select(.value != null and .value != "") | select(.id != "notesPlain") | "\(.label)=\(.value)"' 2>/dev/null || echo "")

    while IFS='=' read -r KEY VALUE; do
        if [ -n "$KEY" ] && [ -n "$VALUE" ]; then
            CLEAN_KEY=$(echo "$KEY" | tr '[:lower:]' '[:upper:]' | tr ' -' '_' | tr -cd '[:alnum:]_')
            ESCAPED_VALUE=$(echo "$VALUE" | sed 's/"/\\"/g')
            echo "set -gx $CLEAN_KEY \"$ESCAPED_VALUE\"" >> "$SECRETS_FILE"
        fi
    done <<< "$FIELDS"

    echo "" >> "$SECRETS_FILE"
done

chmod 600 "$SECRETS_FILE"
echo "Generated secrets file: $SECRETS_FILE"

# Generate AWS config + credentials from 1Password.
#   "AWS SSO: <name>" -> [profile <name>] in config (sso_* / region / output).
#   "AWS Key: <name>" -> access keys in credentials under [<name>]; remaining fields
#                        (region / output) in config under [profile <name>].
# Access keys go in ~/.aws/credentials, never ~/.aws/config.
AWS_DIR="$HOME/.aws"
AWS_CONFIG="$AWS_DIR/config"
AWS_CREDS="$AWS_DIR/credentials"

mkdir -p "$AWS_DIR"
chmod 700 "$AWS_DIR"

echo "# Auto-generated by chezmoi - do not edit" > "$AWS_CONFIG"
echo "# Generated: $(date -Iseconds)" >> "$AWS_CONFIG"
echo "" >> "$AWS_CONFIG"

# config: profile settings (keys excluded for AWS Key items)
echo "$ITEMS" | jq -r '.[] | "\(.title)|\(.vault.id)"' | while IFS='|' read -r TITLE VAULT_ID; do
    if [[ "$TITLE" == "AWS SSO:"* ]]; then
        PROFILE_NAME=$(echo "$TITLE" | sed 's/^AWS SSO: *//')
        IS_KEY=0
    elif [[ "$TITLE" == "AWS Key:"* ]]; then
        PROFILE_NAME=$(echo "$TITLE" | sed 's/^AWS Key: *//')
        IS_KEY=1
    else
        continue
    fi

    echo "[profile $PROFILE_NAME]" >> "$AWS_CONFIG"

    op item get "$TITLE" --vault "$VAULT_ID" --format json 2>/dev/null | \
        jq -r '.fields[]? | select(.value != null and .value != "") | select(.id != "notesPlain") | "\(.label)=\(.value)"' 2>/dev/null | \
        while IFS='=' read -r KEY VALUE; do
            if [ -n "$KEY" ] && [ -n "$VALUE" ]; then
                CLEAN_KEY=$(echo "$KEY" | tr '[:upper:]' '[:lower:]' | tr ' -' '_')
                if [ "$IS_KEY" = "1" ] && { [ "$CLEAN_KEY" = "aws_access_key_id" ] || [ "$CLEAN_KEY" = "aws_secret_access_key" ]; }; then
                    continue
                fi
                echo "$CLEAN_KEY = $VALUE" >> "$AWS_CONFIG"
            fi
        done

    echo "" >> "$AWS_CONFIG"
done

chmod 600 "$AWS_CONFIG"
echo "Generated AWS config: $AWS_CONFIG"

# credentials: access keys only, from "AWS Key: <name>" items, under [<name>]
echo "# Auto-generated by chezmoi - do not edit" > "$AWS_CREDS"
echo "# Generated: $(date -Iseconds)" >> "$AWS_CREDS"
echo "" >> "$AWS_CREDS"

echo "$ITEMS" | jq -r '.[] | "\(.title)|\(.vault.id)"' | while IFS='|' read -r TITLE VAULT_ID; do
    if [[ "$TITLE" != "AWS Key:"* ]]; then
        continue
    fi
    PROFILE_NAME=$(echo "$TITLE" | sed 's/^AWS Key: *//')

    echo "[$PROFILE_NAME]" >> "$AWS_CREDS"

    op item get "$TITLE" --vault "$VAULT_ID" --format json 2>/dev/null | \
        jq -r '.fields[]? | select(.value != null and .value != "") | select(.id != "notesPlain") | "\(.label)=\(.value)"' 2>/dev/null | \
        while IFS='=' read -r KEY VALUE; do
            if [ -n "$KEY" ] && [ -n "$VALUE" ]; then
                CLEAN_KEY=$(echo "$KEY" | tr '[:upper:]' '[:lower:]' | tr ' -' '_')
                if [ "$CLEAN_KEY" = "aws_access_key_id" ] || [ "$CLEAN_KEY" = "aws_secret_access_key" ]; then
                    echo "$CLEAN_KEY = $VALUE" >> "$AWS_CREDS"
                fi
            fi
        done

    echo "" >> "$AWS_CREDS"
done

chmod 600 "$AWS_CREDS"
echo "Generated AWS credentials: $AWS_CREDS"

# Setup SSH key for git operations
SSH_DIR="$HOME/.ssh"
SSH_KEY="$SSH_DIR/id_ed25519"

mkdir -p "$SSH_DIR"
chmod 700 "$SSH_DIR"

# Fetch private key from 1Password (try all vaults)
PRIVATE_KEY=""
for VAULT in "${VAULTS[@]}"; do
    PRIVATE_KEY=$(op read "op://$VAULT/LXC SSH Key/private key" 2>/dev/null || echo "")
    [ -n "$PRIVATE_KEY" ] && break
done

if [ -n "$PRIVATE_KEY" ]; then
    echo "$PRIVATE_KEY" > "$SSH_KEY"
    chmod 600 "$SSH_KEY"

    # Fetch public key from the same vault
    PUBLIC_KEY=""
    for VAULT in "${VAULTS[@]}"; do
        PUBLIC_KEY=$(op read "op://$VAULT/LXC SSH Key/public key" 2>/dev/null || echo "")
        [ -n "$PUBLIC_KEY" ] && break
    done
    if [ -n "$PUBLIC_KEY" ]; then
        echo "$PUBLIC_KEY" > "$SSH_KEY.pub"
        chmod 644 "$SSH_KEY.pub"

        if [ "$IS_DARWIN" != "1" ]; then
            echo "$PUBLIC_KEY" > "$SSH_DIR/authorized_keys"
            chmod 600 "$SSH_DIR/authorized_keys"
            echo "Installed authorized_keys"
        fi
    fi
    echo "Installed SSH key: $SSH_KEY"
else
    echo "WARNING: Could not fetch SSH key from 1Password"
fi
