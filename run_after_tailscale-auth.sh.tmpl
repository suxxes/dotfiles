#!/bin/bash
# chezmoi:template:left-delimiter="# {{" right-delimiter="}}"
# Self-heals Tailscale auth on every apply. Runs after dotfiles applied.
# Bridge host runs its own two-tailnet setup and is excluded.

set -e

# {{ if .bridge }}
exit 0
# {{ end }}

command -v tailscale &> /dev/null || exit 0

# Already authenticated -> no-op
if tailscale ip -1 &> /dev/null; then
    exit 0
fi

echo "==> Re-authenticating Tailscale (no tailnet IP detected)"

if [ -z "$OP_SERVICE_ACCOUNT_TOKEN" ] && [ -f "$HOME/.config/op/service-account-token" ]; then
    export OP_SERVICE_ACCOUNT_TOKEN=$(cat "$HOME/.config/op/service-account-token" | tr -d '[:space:]')
fi

if ! command -v op &> /dev/null; then
    echo "WARNING: 1Password CLI not available; cannot re-auth Tailscale" >&2
    exit 0
fi

PROFILE_TYPE_FILE="/.profile"
if [ -f "$PROFILE_TYPE_FILE" ]; then
    TS_PROFILE_TYPE=$(cat "$PROFILE_TYPE_FILE" | tr -d '[:space:]')
else
    TS_PROFILE_TYPE="default"
fi

if [ "$TS_PROFILE_TYPE" = "work" ]; then
    TS_VAULTS=("Secrets" "Secrets: Work")
elif [ "$TS_PROFILE_TYPE" = "personal" ]; then
    TS_VAULTS=("Secrets" "Secrets: Personal")
else
    TS_VAULTS=("Secrets")
fi

TS_AUTHKEY=""
for VAULT in "${TS_VAULTS[@]}"; do
    TS_AUTHKEY=$(op read "op://$VAULT/Tailscale/Auth Key" 2>/dev/null || echo "")
    [ -n "$TS_AUTHKEY" ] && break
done

if [ -n "$TS_AUTHKEY" ]; then
    sudo tailscale up --authkey="$TS_AUTHKEY" --advertise-tags=tag:lxc
    echo "Tailscale re-authenticated"
else
    echo "WARNING: Could not fetch Tailscale auth key from 1Password" >&2
fi
